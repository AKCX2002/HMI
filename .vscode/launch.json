{
  "version": "0.2.0",
  "configurations": [
    // ═══════════════════════════════════════════
    //  Flutter Linux (Wayland / X11)
    // ═══════════════════════════════════════════
    {
      "name": "Flutter Linux (Debug)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "deviceId": "linux",
      "preLaunchTask": "Flutter: pub get",
      "args": [
        "--enable-wayland-ime" // Wayland IME 支持
      ]
    },
    {
      "name": "Flutter Linux (Profile)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "profile",
      "deviceId": "linux",
      "preLaunchTask": "Flutter: pub get",
      "args": [
        "--enable-wayland-ime"
      ]
    },
    {
      "name": "Flutter Linux (Release)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "release",
      "deviceId": "linux",
      "preLaunchTask": "Flutter: pub get"
    },
    // ═══════════════════════════════════════════
    //  Native ELF Debug (Linux GDB/LLDB)
    // ═══════════════════════════════════════════
    {
      "name": "Native ELF Debug (build/linux/x64/debug)",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build/linux/x64/debug/bundle/hmi_host",
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "terminal": "integrated",
      "preLaunchTask": "Flutter: build linux debug",
      "sourceLanguages": [
        "dart",
        "cpp"
      ]
    },
    {
      "name": "Native ELF Debug (build/runner)",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build/runner/hmi_host",
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "terminal": "integrated",
      "preLaunchTask": "CMake: Configure+Build (debug)"
    },
    {
      "name": "Attach to Running hmi_host",
      "type": "lldb",
      "request": "attach",
      "pid": "${command:pickProcess}",
      "cwd": "${workspaceFolder}"
    },
    // ═══════════════════════════════════════════
    //  Flutter Linux with Wayland-specific flags
    // ═══════════════════════════════════════════
    {
      "name": "Flutter Linux (Wayland Debug)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "deviceId": "linux",
      "preLaunchTask": "Flutter: pub get",
      "args": [
        "--enable-wayland-ime",
        "--disable-gpu" // Wayland 下 GPU 加速有问题时回退软件渲染
      ]
    },
    {
      "name": "Flutter Linux (Wayland — software render)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "deviceId": "linux",
      "preLaunchTask": "Flutter: pub get",
      "env": {
        "FLUTTER_DISABLE_GPU": "1" // 强制软件渲染，排查 Wayland GPU 异常
      }
    }
  ],
  "compounds": [
    {
      "name": "Flutter Run + Attach Native",
      "configurations": [
        "Flutter Linux (Debug)",
        "Attach to Running hmi_host"
      ]
    }
  ]
}
