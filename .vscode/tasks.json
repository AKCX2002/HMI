    {
      "label": "Check Wayland environment",
      "type": "shell",
      "command": "echo 'WAYLAND_DISPLAY=$WAYLAND_DISPLAY' && echo 'XDG_SESSION_TYPE=$XDG_SESSION_TYPE' && echo 'FLUTTER_DISABLE_GPU=$FLUTTER_DISABLE_GPU'",
      "group": "test",
      "problemMatcher": [],
      "detail": "Print Wayland/GPU environment variables for debugging"
    },
    {
      "label": "Install Linux build dependencies",
      "type": "shell",
      "command": "echo 'For Arch Linux: sudo pacman -S clang gtk3 libx11 pkg-config ninja cmake'",
