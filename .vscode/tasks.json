      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "CMake: Configure (win-debug preset)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--preset",
        "win-debug"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "CMake: Build (debug preset)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "build-debug"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "CMake: Configure+Build (debug)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "CMake: Configure (win-debug preset)",
        "CMake: Build (debug preset)"
      ],
      "problemMatcher": []
    },
    {
      "label": "Windows: Enable Developer Mode (open settings)",
      "type": "shell",
      "command": "start",
      "args": [
        "ms-settings:developers"
      ],
      "problemMatcher": []
    },
    {
      "label": "Flutter: build all release",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Flutter: pub get",
        "Flutter: build windows release",
        "Flutter: build web release",
        "Flutter: build apk release",
        "Flutter: build appbundle release",
        "Flutter: build linux release",
        "Flutter: build macos release",
        "Flutter: build ios release"
