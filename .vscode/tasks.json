{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Flutter: pub get",
      "type": "shell",
      "command": "flutter",
      "args": [
        "pub",
        "get"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Flutter: clean",
      "type": "shell",
      "command": "flutter",
      "args": [
        "clean"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Flutter: analyze",
      "type": "shell",
      "command": "dart",
      "args": [
        "analyze"
      ],
      "group": "test",
      "problemMatcher": "$dart"
    },
    {
      "label": "Flutter: test",
      "type": "shell",
      "command": "flutter",
      "args": [
        "test"
      ],
      "group": "test",
      "problemMatcher": "$dart"
    },
    {
